# ===============================================
# AI DISCO BOT — environment variables template
# Copy this file to .env and fill in actual values
# ===============================================

# Telegram Bot Token from @BotFather
# https://t.me/BotFather → /newbot
BOT_TOKEN=

# Your Telegram user ID (creator/admin commands)
# Get yours from @userinfobot
CREATOR_ID=

# GitHub Personal Access Token (fine-grained)
# Needs WRITE permission on the data repository
# Create at: https://github.com/settings/personal-access-tokens/new
GITHUB_TOKEN=

# Repository where bot data (JSON) is stored
# Format: username/repo-name (e.g. ErnestKostevich/telegram-ai-bot-db)
GITHUB_REPO=

# Path to the data file inside the repo (default: bot_data.json)
GITHUB_FILE_PATH=bot_data.json

# This bot is BYOK (Bring Your Own Key) by design — each user provides
# their own AI provider API key. The creator does not subsidize usage.

# ====== Monetization ======
# NOWPayments — get your API key + IPN secret from
#   https://account.nowpayments.io/store-settings (API Keys + Instant Payment Notifications tabs)
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=

# Public URL where this bot serves HTTP. Used by NOWPayments to send webhooks
# AND by the Telegram Mini App button. On Fly.io: usually https://<app>.fly.dev
PUBLIC_BASE_URL=

# Port the HTTP server binds to inside the VM. Default 8080 matches fly.toml.
# WEBHOOK_PORT=8080
