# ===============================================
# AI DISCO BOT — environment variables template
# Copy this file to .env and fill in actual values
# ===============================================

# Telegram Bot Token from @BotFather
# https://t.me/BotFather → /newbot
BOT_TOKEN=

# Your Telegram user ID (creator/admin commands)
# Get yours from @userinfobot
CREATOR_ID=

# GitHub Personal Access Token (fine-grained)
# Needs WRITE permission on the data repository
# Create at: https://github.com/settings/personal-access-tokens/new
GITHUB_TOKEN=

# Repository where bot data (JSON) is stored
# Format: username/repo-name (e.g. ErnestKostevich/telegram-ai-bot-db)
GITHUB_REPO=

# Path to the data file inside the repo (default: bot_data.json)
GITHUB_FILE_PATH=bot_data.json

# ====== Free Tier (optional but highly recommended for growth) ======
# Provide a fallback API key for new users who haven't set their own key.
# Pick one (Groq is recommended — free models, fast).
# Daily limit defaults to 10 messages per user (FREE_TIER_DAILY_LIMIT).
FALLBACK_GROQ_KEY=
FALLBACK_GEMINI_KEY=
FALLBACK_OPENAI_KEY=
FALLBACK_ANTHROPIC_KEY=
FALLBACK_OPENROUTER_KEY=
FALLBACK_MISTRAL_KEY=
FALLBACK_TOGETHER_KEY=
FALLBACK_DEEPSEEK_KEY=

# Override the daily message cap for the free tier (default: 10).
# Set to 0 to disable the free tier entirely.
FREE_TIER_DAILY_LIMIT=10

# When a user's selected provider has no shared key, fall back to this one.
FREE_TIER_FALLBACK_PROVIDER=groq
