# ============================================================
# Environment file for the systemd unit /etc/systemd/system/disco-ai-bot.service
# Place at: /etc/disco-ai-bot/disco-ai-bot.env  (mode 0600, owned root:root)
# NEVER commit real values to git.
# ============================================================

# --- Required ---
BOT_TOKEN=
GITHUB_TOKEN=
GITHUB_REPO=ErnestKostevich/telegram-ai-bot-db
GITHUB_FILE_PATH=bot_data.json
CREATOR_ID=

# --- Monetization (optional but recommended for /buycrypto + Mini App) ---
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
# Set to the public HTTPS URL nginx will forward to this bot. Used by Mini App
# and as the IPN callback target in NOWPayments dashboard.
PUBLIC_BASE_URL=https://disco.example.com

# --- HTTP server ---
# Pick a port that doesn't clash with the other 3 bots on the same VPS.
# Other bots already on 8080 → this bot can take 8081 (or 8082, 8083...).
WEBHOOK_PORT=8081
