# ============================================================
# Environment file for the systemd unit /etc/systemd/system/disco-ai-bot.service
# Place at: /etc/disco-ai-bot/disco-ai-bot.env
#
# Mode 0600 root:root is intentional — systemd reads EnvironmentFile as PID 1
# BEFORE dropping privileges to User=disco-bot, so disco-bot must NOT own it.
# install.sh re-asserts this on every run.
#
# NEVER commit real values to git.
# ============================================================

# --- Required ---
BOT_TOKEN=
GITHUB_TOKEN=
GITHUB_REPO=ErnestKostevich/telegram-ai-bot-db
GITHUB_FILE_PATH=bot_data.json
CREATOR_ID=

# --- Monetization (optional) ---
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=

# --- Mini App / public URL (REQUIRED for Mini App + crypto IPN callbacks) ---
# Set to the public HTTPS URL nginx forwards to this bot, e.g.
#   PUBLIC_BASE_URL=https://disco.yourdomain.com
# Leave COMMENTED OUT until you have a real domain + TLS cert. The bot
# checks for the literal "example.com" and refuses to issue crypto invoices
# against the placeholder (it would silently drop the IPN callback).
# PUBLIC_BASE_URL=

# --- HTTP server ---
# Pick a port that doesn't clash with the other 3 bots on the same VPS.
# Other bots already on 8080 → this bot can take 8081 (or 8082, 8083...).
# Verify before install: sudo ss -ltnp '( sport = :8081 )'
WEBHOOK_PORT=8081
